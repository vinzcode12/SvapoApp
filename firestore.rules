rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isAdmin() {
      // Bootstrapped admin email
      return isSignedIn() && request.auth.token.email.lower() == 'vincenzomerolla78@gmail.com'.lower();
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price']);
    }

    match /products/{productId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /customers/{customerId} {
      allow create: if isValidId(customerId) && isValidCustomer(incoming()) && incoming().keys().size() <= 5; // Anyone can subscribe to offers
      allow read: if isAdmin(); // Only admins can see customer list
      allow update, delete: if isAdmin();
    }
  }
}
